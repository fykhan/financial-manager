# copy to .env and fill in — never commit the real file

# Neon pooled connection string (has "-pooler" in the hostname)
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Neon direct connection string (no "-pooler"), used only for one-off admin tasks
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

AUTH_USERNAME=
# generate with: python scripts/hash_password.py
AUTH_PASSWORD_HASH=
JWT_SECRET=
